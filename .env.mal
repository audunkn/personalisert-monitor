# Intelligence Monitor — Miljøvariabelmal
# Kopier denne filen til .env og fyll inn verdiene

# OpenAI
OPENAI_API_NØKKEL=          # API-nøkkel fra platform.openai.com — brukes til sammendrag og Whisper sky-reserve
OPENAI_MODELL=gpt-4.1
MAKS_SAMMENDRAG_TOKENS=1024
TEMPERATURE=0.3

# Opik (observabilitet)
OPIK_API_NØKKEL=
OPIK_PROSJEKTNAVN=intelligence-monitor

# Database
DATABASE_STI=data/monitor.db

# Obsidian-vault
VAULT_ROT=

# Innhentingsgrenser
MAKS_ARTIKKEL_TOKENS=4000
HENT_FRA=
HENT_TIL=

# E-post / SMTP
SMTP_VERT=
SMTP_PORT=587
SMTP_BRUKER=
SMTP_PASSORD=
VARSLING_TIL_EPOST=
DIGEST_TIL_EPOST=

# Whisper (lokal tale)
WHISPER_MODELL=base
