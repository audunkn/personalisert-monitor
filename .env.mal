# Intelligence Monitor — Miljøvariabelmal
# Kopier denne filen til .env og fyll inn verdiene

# Anthropic
ANTHROPIC_API_NØKKEL=

# Opik (observabilitet)
OPIK_API_NØKKEL=
OPIK_PROSJEKTNAVN=intelligence-monitor

# Database
DATABASE_STI=data/monitor.db

# Obsidian-vault
VAULT_STI=

# Innhentingsgrenser
MAKS_ARTIKKEL_TOKENS=4000
HENT_FRA=
HENT_TIL=

# E-post / SMTP
SMTP_VERT=
SMTP_PORT=587
SMTP_BRUKER=
SMTP_PASSORD=
VARSLING_TIL_EPOST=
DIGEST_TIL_EPOST=

# Whisper (lokal tale)
WHISPER_MODELL=base
OPENAI_API_NØKKEL=
